# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Postgres connection string the backend + scripts read (fails loudly if unset).
# Local:    postgresql://localhost:5432/trailsearch
# Supabase: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend (Vite) — base URL of the FastAPI backend. Read by frontend/src/App.jsx.
VITE_API_URL=http://localhost:8000
